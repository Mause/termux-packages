diff --git a/core/lstream_client.go b/core/lstream_client.go
index 4ac9fe5..1350dc9 100644
--- a/core/lstream_client.go
+++ b/core/lstream_client.go
@@ -1204,7 +1204,7 @@ func roundUpToNextSecond(t time.Time) time.Time {
 // for the particular log stream.
 func (lsc *LStreamClient) getLStreamNerdlogAgentPath() string {
 	return fmt.Sprintf(
-		"/tmp/nerdlog_agent_%s_%s.sh",
+		"$TERMUX_TMP/nerdlog_agent_%s_%s.sh",
 		lsc.params.ClientID,
 		filepathToId(lsc.params.LogStream.LogFileLast()),
 	)
@@ -1214,7 +1214,7 @@ func (lsc *LStreamClient) getLStreamNerdlogAgentPath() string {
 // the particular log stream.
 func (lsc *LStreamClient) getLStreamIndexFilePath() string {
 	return fmt.Sprintf(
-		"/tmp/nerdlog_agent_index_%s_%s",
+		"$TERMUX_TMP/tmp/nerdlog_agent_index_%s_%s",
 		lsc.params.ClientID,
 		filepathToId(lsc.params.LogStream.LogFileLast()),
 	)
