+rustls = { version = "0.23", default-features = false, features = [
+  "std",
+  "tls12"
+], optional = true }
+tokio = { version = "1.0", features = ["fs", "rt"], optional = true }
+
 [target.'cfg(not(target_arch = "wasm32"))'.dev-dependencies]
 benchmark = { path = "../benchmark/" }
